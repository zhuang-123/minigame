<view class="game-page data-v-4a7c3aa6"><view class="nav-bar data-v-4a7c3aa6"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="nav-back data-v-4a7c3aa6" bindtap="__e"><text class="back-icon data-v-4a7c3aa6">←</text></view><view class="nav-title data-v-4a7c3aa6">叫骰游戏</view><view data-event-opts="{{[['tap',[['goToRule',['$event']]]]]}}" class="nav-right data-v-4a7c3aa6" bindtap="__e"><text class="rule-icon data-v-4a7c3aa6">规则</text></view></view><view class="players-section data-v-4a7c3aa6"><block wx:for="{{players}}" wx:for-item="player" wx:for-index="index" wx:key="index"><view class="{{['player-item data-v-4a7c3aa6',(player.isCurrent)?'current-player':'',(player.isWinner)?'winner':'',(player.isLoser)?'loser':'']}}"><view class="player-avatar data-v-4a7c3aa6"><image src="{{player.avatar}}" mode="aspectFill" class="data-v-4a7c3aa6"></image><block wx:if="{{player.isCurrent}}"><view class="current-indicator data-v-4a7c3aa6"><text class="data-v-4a7c3aa6">当前</text></view></block></view><view class="player-info data-v-4a7c3aa6"><view class="player-name data-v-4a7c3aa6">{{player.name}}</view><view class="player-status data-v-4a7c3aa6">{{player.status}}</view><block wx:if="{{player.isCurrent&&!gameEnded&&!isMatching}}"><view class="player-countdown data-v-4a7c3aa6"><text class="countdown-text data-v-4a7c3aa6">{{"剩余时间: "+countdown+"秒"}}</text></view></block></view><block wx:if="{{player.showDice}}"><view class="player-dice data-v-4a7c3aa6"><block wx:for="{{player.dice}}" wx:for-item="dice" wx:for-index="diceIndex" wx:key="diceIndex"><view class="dice-item data-v-4a7c3aa6"><text class="dice-number data-v-4a7c3aa6">{{dice}}</text></view></block></view></block></view></block></view><view class="game-section data-v-4a7c3aa6"><view class="game-card data-v-4a7c3aa6"><view class="game-status data-v-4a7c3aa6"><view class="status-text data-v-4a7c3aa6">{{gameStatus}}</view></view><view class="dice-area data-v-4a7c3aa6"><view class="dice-container data-v-4a7c3aa6"><block wx:for="{{myDice}}" wx:for-item="dice" wx:for-index="index" wx:key="index"><view class="{{['dice-item data-v-4a7c3aa6',(!showMyDice)?'hidden':'']}}"><text class="dice-number data-v-4a7c3aa6">{{dice}}</text></view></block></view></view><block wx:if="{{showCallDice}}"><view class="call-dice-section data-v-4a7c3aa6"><view class="call-dice-header data-v-4a7c3aa6"><text class="call-dice-title data-v-4a7c3aa6">叫骰</text></view><view class="call-dice-row data-v-4a7c3aa6"><text class="call-dice-label data-v-4a7c3aa6">数量：</text><view class="number-buttons data-v-4a7c3aa6"><block wx:for="{{diceNumbers}}" wx:for-item="num" wx:for-index="__i0__" wx:key="*this"><button data-event-opts="{{[['tap',[['selectNumber',['$0'],[[['diceNumbers','',__i0__]]]]]]]}}" class="{{['number-btn data-v-4a7c3aa6',(selectedNumber===num)?'active':'']}}" bindtap="__e">{{''+num+''}}</button></block></view></view><view class="call-dice-row data-v-4a7c3aa6"><text class="call-dice-label data-v-4a7c3aa6">点数：</text><view class="point-buttons data-v-4a7c3aa6"><block wx:for="{{dicePoints}}" wx:for-item="point" wx:for-index="__i1__" wx:key="*this"><button data-event-opts="{{[['tap',[['selectPoint',['$0'],[[['dicePoints','',__i1__]]]]]]]}}" class="{{['point-btn data-v-4a7c3aa6',(selectedPoint===point)?'active':'']}}" bindtap="__e">{{''+point+''}}</button></block></view></view><view class="call-dice-row data-v-4a7c3aa6"><text class="call-dice-label data-v-4a7c3aa6">斋：</text><view class="zhai-buttons data-v-4a7c3aa6"><button data-event-opts="{{[['tap',[['toggleZhai',['$event']]]]]}}" class="{{['zhai-btn data-v-4a7c3aa6',(selectedZhai)?'active':'']}}" bindtap="__e">{{''+(selectedZhai?'是':'否')+''}}</button></view></view><view class="call-dice-actions data-v-4a7c3aa6"><button data-event-opts="{{[['tap',[['cancelCallDice',['$event']]]]]}}" class="action-btn cancel-btn data-v-4a7c3aa6" bindtap="__e">取消</button><button data-event-opts="{{[['tap',[['confirmCallDice',['$event']]]]]}}" class="action-btn confirm-btn data-v-4a7c3aa6" bindtap="__e">确认叫骰</button></view></view></block><block wx:else><block wx:if="{{!gameEnded}}"><view class="action-area data-v-4a7c3aa6"><button class="action-btn pee-btn data-v-4a7c3aa6" disabled="{{!canPee}}" data-event-opts="{{[['tap',[['handlePee',['$event']]]]]}}" bindtap="__e">劈</button><button class="action-btn data-v-4a7c3aa6" disabled="{{!canCall}}" data-event-opts="{{[['tap',[['openCallDice',['$event']]]]]}}" bindtap="__e">叫骰</button><button class="action-btn counter-pee-btn data-v-4a7c3aa6" disabled="{{!canCounterPee}}" data-event-opts="{{[['tap',[['handleCounterPee',['$event']]]]]}}" bindtap="__e">反劈</button><button class="action-btn data-v-4a7c3aa6" disabled="{{!canOpen}}" data-event-opts="{{[['tap',[['openDice',['$event']]]]]}}" bindtap="__e">开</button></view></block><block wx:else><view class="action-area data-v-4a7c3aa6"><button data-event-opts="{{[['tap',[['playAgain',['$event']]]]]}}" class="action-btn play-again-btn data-v-4a7c3aa6" bindtap="__e">再来一局</button></view></block></block></view></view><view class="history-section data-v-4a7c3aa6"><view class="history-header data-v-4a7c3aa6"><text class="history-title data-v-4a7c3aa6">游戏记录</text></view><view class="history-list data-v-4a7c3aa6"><block wx:for="{{gameHistory}}" wx:for-item="record" wx:for-index="index" wx:key="index"><view class="history-item data-v-4a7c3aa6"><text class="history-text data-v-4a7c3aa6">{{record}}</text></view></block></view></view></view>