<view class="game-page data-v-02f1361c"><view class="top-bar data-v-02f1361c"><view class="pot-info data-v-02f1361c"><text class="pot-label data-v-02f1361c">底池</text><text class="pot-amount data-v-02f1361c">{{pot}}</text></view><view class="game-stage data-v-02f1361c"><text class="stage-text data-v-02f1361c">{{stageName}}</text></view><view class="my-chips data-v-02f1361c"><text class="chips-label data-v-02f1361c">筹码</text><text class="chips-amount data-v-02f1361c">{{myChips}}</text></view></view><view class="community-area data-v-02f1361c"><view class="community-cards data-v-02f1361c"><block wx:for="{{communityCards}}" wx:for-item="card" wx:for-index="index" wx:key="index"><view class="{{['community-card data-v-02f1361c',(card.visible)?'visible':'']}}"><block wx:if="{{card.visible}}"><view class="{{['card-inner data-v-02f1361c',card.suit]}}"><text class="card-rank data-v-02f1361c">{{card.rank}}</text><text class="card-suit-icon data-v-02f1361c">{{card.suitIcon}}</text></view></block><block wx:else><view class="card-back data-v-02f1361c"></view></block></view></block></view></view><view class="opponents-area data-v-02f1361c"><block wx:for="{{opponents}}" wx:for-item="player" wx:for-index="index" wx:key="index"><view class="{{['player-seat data-v-02f1361c',(player.isActive)?'active':'',(player.folded)?'folded':'']}}"><view class="avatar data-v-02f1361c">{{player.avatar}}</view><view class="player-name data-v-02f1361c">{{player.name}}</view><view class="player-chips data-v-02f1361c">{{player.chips}}</view><block wx:if="{{player.isActive}}"><view class="thinking-dot data-v-02f1361c"><view class="dot d1 data-v-02f1361c"></view><view class="dot d2 data-v-02f1361c"></view><view class="dot d3 data-v-02f1361c"></view></view></block><block wx:if="{{player.isDealer}}"><view class="dealer-btn data-v-02f1361c">D</view></block><block wx:if="{{player.blind}}"><view class="blind-btn data-v-02f1361c">{{player.blind}}</view></block></view></block></view><view class="my-hand-area data-v-02f1361c"><view class="my-cards data-v-02f1361c"><block wx:for="{{myCards}}" wx:for-item="card" wx:for-index="i" wx:key="i"><view class="{{['my-card data-v-02f1361c',card.suit]}}"><text class="card-rank data-v-02f1361c">{{card.rank}}</text><text class="card-suit-icon data-v-02f1361c">{{card.suitIcon}}</text></view></block></view><view class="my-info data-v-02f1361c"><view class="my-bet-info data-v-02f1361c"><text class="bet-label data-v-02f1361c">当前下注</text><text class="bet-amount data-v-02f1361c">{{myBet}}</text></view></view></view><block wx:if="{{isMyTurn}}"><view class="action-area data-v-02f1361c"><block wx:if="{{showBetSlider}}"><view class="bet-slider-row data-v-02f1361c"><text class="slider-label data-v-02f1361c">{{"下注额："+betAmount}}</text><slider min="{{minBet}}" max="{{myChips}}" value="{{betAmount}}" block-size="28" activeColor="#f0c048" backgroundColor="rgba(255,255,255,0.1)" data-event-opts="{{[['change',[['onSliderChange',['$event']]]]]}}" bindchange="__e" class="data-v-02f1361c"></slider></view></block><view class="action-btns data-v-02f1361c"><button data-event-opts="{{[['tap',[['onFold',['$event']]]]]}}" class="action-btn fold-btn data-v-02f1361c" bindtap="__e">弃牌</button><block wx:if="{{canCheck}}"><button data-event-opts="{{[['tap',[['onCheck',['$event']]]]]}}" class="action-btn check-btn data-v-02f1361c" bindtap="__e">过牌</button></block><block wx:else><button data-event-opts="{{[['tap',[['onCall',['$event']]]]]}}" class="action-btn call-btn data-v-02f1361c" bindtap="__e">{{"跟注 "+callAmount}}</button></block><button data-event-opts="{{[['tap',[['onRaise',['$event']]]]]}}" class="action-btn raise-btn data-v-02f1361c" bindtap="__e">加注</button><button data-event-opts="{{[['tap',[['onAllIn',['$event']]]]]}}" class="action-btn allin-btn data-v-02f1361c" bindtap="__e">全下</button></view></view></block><block wx:else><view class="waiting-tip data-v-02f1361c"><view class="wait-dot-row data-v-02f1361c"><view class="wait-dot wd1 data-v-02f1361c"></view><view class="wait-dot wd2 data-v-02f1361c"></view><view class="wait-dot wd3 data-v-02f1361c"></view></view><text class="wait-text data-v-02f1361c">等待其他玩家行动...</text></view></block><block wx:if="{{logs.length>0}}"><view class="game-log data-v-02f1361c"><block wx:for="{{logs}}" wx:for-item="log" wx:for-index="i" wx:key="i"><view class="log-item data-v-02f1361c">{{log}}</view></block></view></block><block wx:if="{{gameState==='waiting'}}"><view class="start-mask data-v-02f1361c"><view class="start-card data-v-02f1361c"><view class="start-icon data-v-02f1361c">♠️</view><view class="start-title data-v-02f1361c">德州扑克</view><view class="start-desc data-v-02f1361c">正在等待玩家加入...</view><button data-event-opts="{{[['tap',[['startGame',['$event']]]]]}}" class="start-game-btn data-v-02f1361c" bindtap="__e">开始游戏</button><view data-event-opts="{{[['tap',[['goToRule',['$event']]]]]}}" class="start-rule-link data-v-02f1361c" bindtap="__e">查看规则 →</view></view></view></block><block wx:if="{{gameState==='matching'}}"><view class="start-mask data-v-02f1361c"><view class="start-card data-v-02f1361c"><view class="start-icon data-v-02f1361c">🔄</view><view class="start-title data-v-02f1361c">匹配中</view><view class="start-desc data-v-02f1361c">正在寻找对手...</view><block wx:if="{{matchState.players.length>0}}"><view class="player-list data-v-02f1361c"><block wx:for="{{matchState.players}}" wx:for-item="player" wx:for-index="index" wx:key="index"><view class="player-item data-v-02f1361c"><view class="player-avatar data-v-02f1361c">{{player.avatar}}</view><view class="player-info data-v-02f1361c"><view class="player-name data-v-02f1361c">{{player.name}}</view><view class="{{['player-status data-v-02f1361c',player.ready?'ready':'waiting']}}">{{''+(player.ready?'已准备':'等待准备')+''}}</view></view></view></block></view></block><block wx:if="{{matchState.players.length>=2}}"><button data-event-opts="{{[['tap',[['readyGame',['$event']]]]]}}" class="start-game-btn data-v-02f1361c" bindtap="__e">准备开始</button></block><button data-event-opts="{{[['tap',[['cancelMatch',['$event']]]]]}}" class="cancel-btn data-v-02f1361c" bindtap="__e">取消匹配</button></view></view></block><block wx:if="{{gameState==='ready'}}"><view class="start-mask data-v-02f1361c"><view class="start-card data-v-02f1361c"><view class="start-icon data-v-02f1361c">✅</view><view class="start-title data-v-02f1361c">准备就绪</view><view class="start-desc data-v-02f1361c">等待所有玩家准备...</view><view class="player-list data-v-02f1361c"><block wx:for="{{matchState.players}}" wx:for-item="player" wx:for-index="index" wx:key="index"><view class="player-item data-v-02f1361c"><view class="player-avatar data-v-02f1361c">{{player.avatar}}</view><view class="player-info data-v-02f1361c"><view class="player-name data-v-02f1361c">{{player.name}}</view><view class="{{['player-status data-v-02f1361c',player.ready?'ready':'waiting']}}">{{''+(player.ready?'已准备':'等待准备')+''}}</view></view></view></block></view><button data-event-opts="{{[['tap',[['cancelReady',['$event']]]]]}}" class="cancel-btn data-v-02f1361c" bindtap="__e">取消准备</button></view></view></block></view>