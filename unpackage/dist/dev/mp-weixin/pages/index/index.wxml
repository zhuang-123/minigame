<view class="content"><image class="logo" src="/static/logo.png"></image><view class="text-area"><text class="title">{{title}}</text></view><block wx:if="{{showPhoneAuthModal}}"><view class="overlay phone-overlay" catchtouchmove="true"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="overlay-mask" bindtap="__e"></view><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="dialog" catchtap="__e"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="dialog-close" bindtap="__e">×</view><view class="dialog-title">手机号授权</view><view class="dialog-body"><view class="field"><text class="label">授权手机号用于提交和服务通知</text></view></view><view class="dialog-actions"><button data-event-opts="{{[['tap',[['e2',['$event']]]]]}}" bindtap="__e">取消</button><button open-type="getPhoneNumber" data-event-opts="{{[['getphonenumber',[['onGetPhoneNumber',['$event']]]]]}}" bindgetphonenumber="__e">去授权</button></view></view></view></block><view class="game-list"><block wx:for="{{gameList}}" wx:for-item="game" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['enterGame',['$0'],[[['gameList','',index]]]]]]]}}" class="game-item" bindtap="__e"><view class="game-icon"><text class="icon-text">{{game.icon}}</text></view><view class="game-name">{{game.name}}</view><view class="game-desc">{{game.desc}}</view></view></block></view></view>