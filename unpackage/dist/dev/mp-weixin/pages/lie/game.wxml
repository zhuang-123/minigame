ner?'🏆':'🎮'}}</view><view class="end-title data-v-09d98812">{{isWinner?'游戏胜利！':'游戏结束'}}</view><view class="ranking-list data-v-09d98812"><view class="ranking-title data-v-09d98812">最终排名</view><block wx:for="{{rankingList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['ranking-item data-v-09d98812',(item.name===myName)?'my-rank':'']}}"><view class="rank-number data-v-09d98812"><block wx:if="{{index===0}}"><text class="data-v-09d98812">🥇</text></block><block wx:else><block wx:if="{{index===1}}"><text class="data-v-09d98812">🥈</text></block><block wx:else><block wx:if="{{index===2}}"><text class="data-v-09d98812">🥉</text></block><block wx:else><text class="data-v-09d98812">{{index+1}}</text></block></block></block></view><view class="rank-name data-v-09d98812">{{item.name}}</view><view class="rank-position data-v-09d98812">{{"第"+item.rank+"名"}}</view></view></block></view><button data-event-opts="{{[['tap',[['restartGame',['$event']]]]]}}" class="end-btn data-v-09d98812" bindtap="__e">再来一局</button></view></view></block></view>