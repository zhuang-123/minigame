<view class="container data-v-54979e85"><view class="progress-container data-v-54979e85"><view class="progress-bar data-v-54979e85"><view class="progress-fill data-v-54979e85" style="{{'width:'+(progressWidth+'%')+';'}}"></view></view><text class="progress-text data-v-54979e85">{{currentQuestion+1+" / "+questions.length}}</text></view><block wx:if="{{questions.length>0}}"><view class="question-card data-v-54979e85"><text class="question-text data-v-54979e85">{{questions[currentQuestion].title}}</text><view class="options-list data-v-54979e85"><block wx:for="{{questions[currentQuestion].options}}" wx:for-item="option" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['selectOption',[index]]]]]}}" class="{{['option-item data-v-54979e85',(selectedOption===index)?'selected':'']}}" bindtap="__e"><text class="option-label data-v-54979e85">{{option.option}}</text><text class="option-text data-v-54979e85">{{option.option_title}}</text></view></block></view></view></block><block wx:else><view class="loading data-v-54979e85"><text class="loading-text data-v-54979e85">加载中...</text></view></block><view class="nav-buttons data-v-54979e85"><button class="nav-btn prev-btn data-v-54979e85" disabled="{{currentQuestion===0}}" data-event-opts="{{[['tap',[['prevQuestion',['$event']]]]]}}" bindtap="__e">上一题</button><button class="nav-btn next-btn data-v-54979e85" disabled="{{selectedOption===-1}}" data-event-opts="{{[['tap',[['nextQuestion',['$event']]]]]}}" bindtap="__e">{{''+(currentQuestion===questions.length-1?'完成测试':'下一题')+''}}</button></view></view>